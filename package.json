{
  "name": "cc-daemon",
  "version": "1.0.0",
  "description": "CC Session Daemon - Orchestrates Claude Code sessions for perpetual autonomous task execution",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cc-daemon": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/gui/static dist/gui/",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "claude",
    "claude-code",
    "agent",
    "session",
    "daemon"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@types/ws": "^8.18.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "node-pty": "^1.1.0",
    "proper-lockfile": "^4.1.2",
    "uuid": "^11.0.5",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/proper-lockfile": "^4.0.9",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
